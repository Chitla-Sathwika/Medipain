# Copy this file to .env and fill in your values

PORT=4000
JWT_SECRET=change_this_to_a_long_random_string

# Optional: only needed for the "Ask AI" chatbot feature (Section 9 of the spec).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Without ANTHROPIC_API_KEY the /api/ai/ask and /api/ai/explain endpoints
# fall back to canned, rule-based explanations pulled from the seed data,
# so the app still works end-to-end with zero cost.
